{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build tree",
            "type": "shell",
            "command": "${workspaceFolder}/build_cuda.sh",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Incremental split build: g++ for CPU sources, nvcc for tree_cuda.cpp."
        },
        {
            "label": "Build tree (clean)",
            "type": "shell",
            "command": "${workspaceFolder}/build_cuda.sh",
            "args": [
                "clean"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Remove build/ artifacts and the tree binary."
        },
        {
            "label": "Build tree (CPU only)",
            "type": "shell",
            "command": "/usr/bin/g++",
            "args": [
                "-fdiagnostics-color=always",
                "-std=c++20",
                "-O2",
                "-pthread",
                "-I.",
                "main.cpp",
                "tree_base.cpp",
                "tree_parallel.cpp",
                "tree_serial.cpp",
                "task_executor.cpp",
                "dataset.cpp",
                "node.cpp",
                "options.cpp",
                "pruning/pruning.cpp",
                "-o",
                "${workspaceFolder}/tree_cpu"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "g++ build without tree_cuda.cpp (use TreeSerial/TreeParallel in main)."
        }
    ]
}
