{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build tree",
            "command": "/usr/bin/g++",
            "args": [
                "-fdiagnostics-color=always",
                "-std=c++17",
                "-O2",
                "-pthread",
                "-I.",
                "main.cpp",
                "c45_tree.cpp",
                "task_executor.cpp",
                "dataset.cpp",
                "node.cpp",
                "tree_visualization.cpp",
                "pruning/cart_prune_cost_complexity.cpp",
                "pruning/c45_prune_c45_pessimistic.cpp",
                "-o",
                "${workspaceFolder}/tree"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Build the full decision tree project."
        }
    ],
    "version": "2.0.0"
}
